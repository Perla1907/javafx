<?xml version="1.0" encoding="UTF-8"?>

<!-- Corrección en las cabeceras xmlns para evitar errores de renderizado en JavaFX -->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane minHeight="600.0" minWidth="800.0" prefHeight="768.0" prefWidth="1024.0" style="-fx-font-size: 14px; -fx-font-family: 'Segoe UI', Arial, sans-serif;" stylesheets="@css/reportes_area.css" xmlns="http://javafx.com" xmlns:fx="http://javafx.com">
   <!-- MENÚ LATERAL IZQUIERDO -->
   <left>
      <!-- Se incrementa a prefWidth de 240px y minWidth con candado USE_PREF_SIZE para evitar que los textos del menú colapsen verticalmente -->
      <VBox fx:id="barraMenu" maxWidth="-Infinity" minWidth="-Infinity" prefWidth="240.0" spacing="8.0" style="-fx-background-color: #094880;" BorderPane.alignment="TOP_LEFT">
         <children>
            <Label fx:id="labelReportes1" prefHeight="46.0" text="Reportes" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="20.0" /> <!-- Sube de 16 a 20 -->
               </font>
               <VBox.margin>
                  <Insets bottom="10.0" left="15.0" />
               </VBox.margin>
            </Label>
            <Button fx:id="btnArea1" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="48.0" styleClass="menu" text="Accesos por área" textFill="WHITE" wrapText="true" />
            <Button fx:id="btnDia1" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="48.0" styleClass="menu" text="Accesos por día" textFill="WHITE" wrapText="true" />
            <Button fx:id="btnHorarios1" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="48.0" styleClass="menu" text="Horarios de mayor uso" textFill="WHITE" wrapText="true" />
            <Button fx:id="btnUsuarios1" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="48.0" styleClass="menu" text="Usuarios más frecuentes" textFill="WHITE" wrapText="true" />
         </children>
         <padding>
            <Insets bottom="15.0" left="10.0" right="10.0" top="15.0" />
         </padding>
      </VBox>
   </left>

   <!-- ÁREA CENTRAL DE CONTENIDO -->
   <center>
      <VBox spacing="25.0" BorderPane.alignment="CENTER">
         <children>
            <!-- TÍTULO DEL REPORTE -->
            <Label text="Reporte: Accesos por área" textFill="#094880">
               <font>
                  <Font name="System Bold" size="26.0" /> <!-- Sube de 18 a 26 para imponer presencia -->
               </font>
            </Label>
            
            <!-- BLOQUE DE FILTROS (FECHAS Y BOTÓN GENERAR) -->
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <!-- Ajustado a un ancho cómodo de 380px para que las cajas de fecha no se aplasten con textos grandes -->
                  <VBox maxWidth="-Infinity" prefWidth="380.0" spacing="15.0">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <Label prefWidth="100.0" text="Fecha inicio:" />
                              <DatePicker fx:id="fechaInicio1" maxWidth="1.7976931348623157E308" prefHeight="35.0" HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <Label prefWidth="100.0" text="Fecha fin:" />
                              <DatePicker fx:id="fechaFin1" maxWidth="1.7976931348623157E308" prefHeight="35.0" HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  
                  <Pane HBox.hgrow="ALWAYS" />
                  
                  <Button fx:id="btnGenerar1" mnemonicParsing="false" prefHeight="40.0" prefWidth="130.0" style="-fx-background-color: #094880;" text="Generar" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
            
            <!-- TABLA CONTROLADA (Mantendrá sus proporciones en pantalla completa) -->
            <TableView maxHeight="380.0" minHeight="250.0" prefHeight="350.0" VBox.vgrow="SOMETIMES">
               <columns>
                  <TableColumn prefWidth="350.0" text="Área académica" />
                  <TableColumn prefWidth="180.0" text="Total de accesos" />
                  <TableColumn prefWidth="150.0" text="Porcentaje" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            
            <!-- Resorte vertical inferior para empujar los botones manteniendo la estética -->
            <Pane VBox.vgrow="ALWAYS" />
            
            <!-- BOTONES DE EXPORTACIÓN (Perfectamente centrados abajo con fuentes optimizadas) -->
            <HBox alignment="CENTER" spacing="50.0">
               <children>
                  <Button mnemonicParsing="false" prefHeight="42.0" prefWidth="180.0" text="Exportar a Excel">
                     <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true" />
                     </graphic>
                  </Button>
                  <Button mnemonicParsing="false" prefHeight="42.0" prefWidth="180.0" text="Exportar a PDF">
                     <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true" />
                     </graphic>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="5.0" top="10.0" />
               </padding>
            </HBox>
         </children>
         <padding>
            <Insets bottom="35.0" left="35.0" right="35.0" top="35.0" />
         </padding>
      </VBox>
   </center>
</BorderPane>
