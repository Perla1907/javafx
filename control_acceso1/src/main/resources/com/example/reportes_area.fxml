<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<!--
  CAMBIOS CLAVE PARA QUE SEA RESPONSIVE:
  1. Se quitaron minHeight/maxHeight = "-Infinity" del AnchorPane raíz (eso lo fijaba a tamaño constante).
  2. El BorderPane ahora se ancla a los 4 lados (0,0,0,0) del AnchorPane raíz -> crece con la ventana.
  3. Los hijos del AnchorPane central usan AnchorPane.topAnchor / leftAnchor / rightAnchor / bottomAnchor
     en lugar de layoutX / layoutY -> se reposicionan y estiran al cambiar el tamaño.
  4. La TableView se ancla a los 4 lados -> ocupa siempre el espacio disponible, no un tamaño fijo.
  5. Los botones de exportar se anclan al fondo (bottomAnchor) en vez de una posición Y fija.
-->
<AnchorPane fx:id="root" prefHeight="400.0" prefWidth="600.0" stylesheets="@css/reportes_area.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.PrimaryController">
   <children>
      <BorderPane AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0">
         <left>
            <VBox prefHeight="400.0" prefWidth="155.0" minWidth="155.0" style="-fx-background-color: #094880;" BorderPane.alignment="CENTER_LEFT">
               <children>
                  <Label fx:id="labelReportes" prefHeight="46.0" prefWidth="162.0" text="Reportes" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                  </Label>
                  <Button fx:id="btnArea" mnemonicParsing="false" prefHeight="43.0" prefWidth="165.0" styleClass="menu" text="Accesos por área" textFill="WHITE" wrapText="true" />
                  <Button fx:id="btnDia" mnemonicParsing="false" prefHeight="43.0" prefWidth="165.0" styleClass="menu" text="Accesos por día" textFill="WHITE" />
                  <Button fx:id="btnHorarios" mnemonicParsing="false" prefHeight="43.0" prefWidth="165.0" styleClass="menu" text="Horarios de mayor uso" textFill="WHITE" />
                  <Button fx:id="btnUsuarios" mnemonicParsing="false" prefHeight="43.0" prefWidth="165.0" styleClass="menu" text="Usuarios más frecuentes" textFill="WHITE" />
               </children>
            </VBox>
         </left>
         <center>
            <!--
              Se sustituye el posicionamiento libre (topAnchor/leftAnchor fijos en px) por
              un VBox que reparte el espacio verticalmente, con un GridPane para la fila de
              filtros (crece proporcionalmente en horizontal) y un HBox para los botones
              inferiores. Así todo el bloque escala junto, en vez de que unos elementos se
              estiren y otros se queden fijos.
            -->
            <VBox styleClass="panelReporte" spacing="14" BorderPane.alignment="CENTER">
               <padding>
                  <Insets top="10.0" right="23.0" bottom="16.0" left="23.0" />
               </padding>
               <children>
                  <Label styleClass="tituloReporte" text="Reporte: Accesos por área" textFill="#094880">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                  </Label>

                  <GridPane hgap="10.0" vgap="10.0">
                     <columnConstraints>
                        <ColumnConstraints halignment="LEFT" minWidth="80.0" prefWidth="90.0" />
                        <ColumnConstraints minWidth="180.0" prefWidth="220.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="0.0" />
                        <ColumnConstraints halignment="RIGHT" minWidth="100.0" prefWidth="110.0" />
                     </columnConstraints>
                     <children>
                        <Label text="Fecha inicio:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <DatePicker fx:id="fechaInicio" maxWidth="1.7976931348623157E308" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                        <Label text="Fecha fin:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <DatePicker fx:id="fechaFin" maxWidth="1.7976931348623157E308" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                        <Button fx:id="btnGenerar" mnemonicParsing="false" text="Generar" textFill="WHITE" GridPane.columnIndex="3" GridPane.rowIndex="0" GridPane.rowSpan="2" GridPane.valignment="CENTER">
                           <font>
                              <Font size="14.0" />
                           </font>
                        </Button>
                     </children>
                  </GridPane>

                  <TableView VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn editable="false" prefWidth="197.60004043579102" text="Área acádemica" />
                      <TableColumn prefWidth="116.79997253417969" text="Total de accesos" />
                        <TableColumn prefWidth="87.199951171875" text="Porcentaje" />
                    </columns>
                  </TableView>

                  <HBox alignment="CENTER" spacing="20.0">
                     <children>
                        <Button fx:id="btnExcel" mnemonicParsing="false" text="Exportar a Excel">
                           <graphic>
                              <ImageView fitHeight="16.0" fitWidth="14.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@images/excel.png" />
                                 </image></ImageView>
                           </graphic>
                        </Button>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnPDF" mnemonicParsing="false" text="Exportar a PDF">
                           <graphic>
                              <ImageView fitHeight="16.0" fitWidth="14.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@images/pdf.png" />
                                 </image></ImageView>
                           </graphic>
                        </Button>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </center>
      </BorderPane>
   </children>
</AnchorPane>
